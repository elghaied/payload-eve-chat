# MongoDB. Local dev: a local mongod (mongodb://127.0.0.1/your-database-name).
# Vercel/production: a MongoDB Atlas SRV string (mongodb+srv://USER:PASS@cluster/db).
DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# --- Eve agent (Vercel Eve framework, via Vercel AI Gateway) ---
# Default model supports Eve's NATIVE built-in tools (web_search etc.) and strong tool calling.
EVE_MODEL=anthropic/claude-haiku-4.5  # cheaper native swaps: google/gemini-2.5-flash, openai/gpt-4o-mini
# EVE_PROVIDER=groq                   # OPTIONAL: pin the serving provider. Only needed for models
                                      # whose creator isn't the provider (e.g. openai/gpt-oss-120b,
                                      # served by groq). Such models DON'T support native web_search.
# AI Gateway auth: run `vercel env pull .env.local` (writes VERCEL_OIDC_TOKEN) for local dev,
# or set AI_GATEWAY_API_KEY. The gateway needs a credit card on the linked Vercel team.
# Without BYOK the gateway uses Vercel's own provider integration and bills your Vercel AI
# Gateway credits. To bill your own provider account instead, add it under
# AI Gateway -> Bring Your Own Key in the Vercel dashboard.

# Image generation (Vercel AI Gateway image model)
# Default: google/imagen-4.0-fast-generate-001 ($0.02/image). One image per generateImage call.
# The agent calls generateImage only when the user requests an illustrated article or explicit
# image generation — not on every post (the tool description and instructions both gate it).
# Override with any gateway-supported image model:
#   EVE_IMAGE_MODEL=xai/grok-imagine-image          # also ~$0.02/image
#   EVE_IMAGE_MODEL=bytedance/seedream-4.0           # ~$0.03/image
# Only models that support the `aspectRatio` parameter are compatible with the default 16:9 flow.
# EVE_IMAGE_MODEL=google/imagen-4.0-fast-generate-001

MCP_SERVER_URL=http://localhost:3000/api/mcp
MCP_API_KEY=                          # optional in dev; required in production

# --- Voice (Deepgram: streaming STT + Aura TTS) ---
# New Deepgram accounts get $200 free credit (no card): https://console.deepgram.com/signup
# The key ALWAYS stays server-side. STT: the browser opens Deepgram's WS with a short-lived
# token from /api/deepgram/token. TTS: proxied through /api/deepgram/speak with the key (grant
# tokens are ASR-scoped only, so Aura TTS can't use them).
# IMPORTANT — key permissions: create a key with the "Member" role and DEFAULT (full) scopes.
#   - A lower-than-Member key → /v1/auth/grant 403 "Insufficient permissions" (STT fails).
#   - A key restricted to ASR scope only → STT works but TTS is silent (Aura returns no audio).
# Don't add inline comments/spaces after the value (the key is trimmed, but keep it clean).
DEEPGRAM_API_KEY=
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en   # optional: any Aura voice

# --- Web search ---
# Eve's provider-native web_search + the built-in web_fetch run through the AI Gateway — no
# SearXNG, no extra key. Native web_search returns clickable result links. A client-side stall
# watchdog (EveChat) aborts a turn after 60s of silence so a stalled provider stream can't hang
# the chat. If native search stalls often on your model, switch EVE_MODEL to a Sonnet/Opus
# Anthropic model (broader server-tool support).
#
# The previous Vercel-AI-SDK setup (AI_PROVIDER / ANTHROPIC_API_KEY / OPENAI_API_KEY /
# OLLAMA_* / self-hosted STT_*/TTS_* / SEARXNG_*) lives only on the `ai-sdk` branch.

# --- Unsplash photo search (optional) ---
# Enables Eve's searchPhotos + addPhotoToMedia tools (fetch a real photo from Unsplash
# into the Media collection, as an alternative to generateImage). When unset, the tools
# are not registered and Eve won't offer them. Create a free app at
# https://unsplash.com/oauth/applications and copy the "Access Key".
# Demo tier is rate-limited to 50 requests/hour. Attribution is handled automatically
# (the photographer credit is stored on Media and shown in the article).
UNSPLASH_ACCESS_KEY=
