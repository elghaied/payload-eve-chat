DATABASE_URL=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE

# --- Eve chat agent ---
AI_PROVIDER=anthropic            # one of: anthropic | openai | ollama
ANTHROPIC_API_KEY=               # required when AI_PROVIDER=anthropic
OPENAI_API_KEY=                  # required when AI_PROVIDER=openai
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
# Ollama runs models locally and needs no API key. Use a tool-calling-capable
# model (the agent drives Posts/Tasks via MCP tools): e.g. qwen2.5, llama3.1, mistral-nemo.
OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434/api
MCP_SERVER_URL=http://localhost:3000/api/mcp
MCP_API_KEY=                     # optional in dev; required in production

# --- Eve voice (STT + TTS) — OPTIONAL ---
# Leave unset for chat-only. Set a base URL to "attach" that service; the other
# vars only matter once it is attached. Both speak the OpenAI audio API, so any
# compatible server (local docker or cloud) works by changing the base URL.
# Local docker (run: docker compose --profile voice up -d):
# STT_BASE_URL=http://localhost:8000/v1
# STT_MODEL=Systran/faster-whisper-small
# STT_API_KEY=                   # only for cloud STT (e.g. OpenAI)
# TTS_BASE_URL=http://localhost:8880/v1
# TTS_MODEL=kokoro
# TTS_VOICE=af_sky
# TTS_FORMAT=mp3
# TTS_API_KEY=                   # only for cloud TTS (e.g. OpenAI)
