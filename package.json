{
  "name": "payload-eve-chat",
  "version": "1.0.0",
  "description": "AI chat agent (Eve) built inside Payload CMS on the Vercel Eve framework — MCP tools (Posts/Tasks), built-in web search, approve-before-create post preview, and hands-free Deepgram voice. Vercel-native and deployable to Vercel.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/copy-vad-assets.mjs && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "node scripts/copy-vad-assets.mjs && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "node scripts/copy-vad-assets.mjs && rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "postinstall": "node scripts/copy-vad-assets.mjs",
    "vad:assets": "node scripts/copy-vad-assets.mjs",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "canary",
    "@payloadcms/next": "canary",
    "@payloadcms/plugin-mcp": "canary",
    "@payloadcms/richtext-lexical": "canary",
    "@payloadcms/ui": "canary",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@ricky0123/vad-web": "^0.0.30",
    "@rive-app/react-webgl2": "^4.29.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@vercel/connect": "0.2.2",
    "@xyflow/react": "^12.11.0",
    "ai": "7.0.0-beta.178",
    "ansi-to-react": "^6.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "embla-carousel-react": "^8.6.0",
    "eve": "0.11.7",
    "graphql": "^16.8.1",
    "lucide-react": "^1.21.0",
    "media-chrome": "^4.19.2",
    "motion": "^12.40.0",
    "nanoid": "^5.1.14",
    "next": "16.2.7",
    "payload": "canary",
    "radix-ui": "^1.6.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-jsx-parser": "^2.4.1",
    "shadcn": "^4.11.0",
    "sharp": "0.34.2",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "tsx": "4.21.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
